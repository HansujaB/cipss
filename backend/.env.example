# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/impact_db

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Google Cloud / Vertex AI (Gemini) ─────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash
# Auth: set GOOGLE_APPLICATION_CREDENTIALS env var pointing
# to your service account JSON key file, or run on GCE/Cloud Run
# where default credentials are available.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
